# Опционально: кнопка «Обновить данные» вызывает ETL перед пересчётом отчёта
# DB_REFRESH_SQL=SELECT brak_team.refresh_write_offs()
# DB_REFRESH_URL=https://example.com/api/sync-write-offs
# DB_REFRESH_METHOD=POST
# DB_REFRESH_TOKEN=
# DB_REFRESH_TIMEOUT=120

# Защита ручного обновления /api/refresh
# REFRESH_API_TOKEN=change-me
# Если токен задан, кнопка "Обновить данные" доступна только администратору
# Полноценная авторизация админа (окно логин/пароль):
# ADMIN_LOGIN=admin
# ADMIN_PASSWORD=change-me
# ADMIN_SESSION_TTL_SEC=28800

# Производительность
# REPORT_CACHE_TTL_SEC=120
# WEEKS_CACHE_TTL_SEC=300

# Материализованное представление для отчёта (рекомендуется для снижения нагрузки)
# USE_WRITE_OFFS_MATVIEW=1
# WRITE_OFFS_MATVIEW_NAME=brak_team.write_offs_weekly_mv
# WRITE_OFFS_MATVIEW_REFRESH_CONCURRENTLY=1
# MATVIEW_BOOTSTRAP_TTL_SEC=600
